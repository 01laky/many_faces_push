# EditorConfig — many_faces_push (tabs; Go uses gofmt tabs by default)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = tab
indent_size = 4
tab_width = 4

[*.go]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{yml,yaml,sh,md}]
indent_style = tab
indent_size = 2
tab_width = 2

[*.md]
trim_trailing_whitespace = false

[many_faces_proto/**]
indent_style = space
indent_size = 2

[gen/**]
indent_style = tab
indent_size = 4
