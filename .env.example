# Optional host port for gRPC when debugging from the laptop (default in docker-compose.yml: 59203).
# PUSH_WORKER_GRPC_HOST_PORT=59203

# In-container listen address (set in docker-compose.yml by default).
# PUSH_WORKER_GRPC_LISTEN=:50053

# Absolute host path to the Firebase service account JSON (enables docker-compose.credentials.yml bind mount).
# If unset, scripts/start-push-worker.sh uses ./firebase-sa.json in this repo root when that file exists.
# FIREBASE_SA_HOST_PATH=/absolute/path/to/firebase-adminsdk-xxxxx.json

# Optional shared secret for gRPC metadata (must match many_faces_backend Push:WorkerAuthToken).
# PUSH_WORKER_EXPECTED_TOKEN=dev-shared-secret

# Dev-only: set to 0 to disable grpcurl reflection in the running container.
# PUSH_WORKER_GRPC_REFLECTION=1

# --- Firebase (from GoogleService-Info.plist at repo root, gitignored) ---
# Map plist keys → env names for the Go worker / ops (do not commit API_KEY from the plist).
# FIREBASE_PROJECT_ID=many-faces-ai              # plist: PROJECT_ID
# FIREBASE_IOS_BUNDLE_ID=com.manyfaces.mobile   # plist: BUNDLE_ID
# FIREBASE_GCM_SENDER_ID=307911834658           # plist: GCM_SENDER_ID
# FIREBASE_GOOGLE_APP_ID=1:307911834658:ios:64c84f538414c9cd6c5e7b  # plist: GOOGLE_APP_ID
# FIREBASE_STORAGE_BUCKET=many-faces-ai.firebasestorage.app  # plist: STORAGE_BUCKET
#
# Server-side FCM uses Firebase Admin with a service account (not the plist API key):
# GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/firebase-sa.json
